{
  "name": "mobile-view-user",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "buildzip": "ng build --configuration production ; cd .. ; cd dist-zip/ ; zip -r mobile.zip mobile/ ; cd ../mobile-view-user",
    "build": "npm i ; ng build --configuration production ; npm run deploy",
    "buildloc": "npm i & ng build --configuration production ; npm run deployloc",
    "build:prod": "npm i ; ng build --configuration production ; npm run deploy:prod",
    "deployloc": "rm -rf /var/www/allow24.in/mdev ; mkdir /var/www/allow24.in/mdev ; scp -r /home/aura-exch-front/mobile-view-user/dist/* /var/www/allow24.in/mdev",
    "deploy": "ssh new-development -a rm -rf /var/www/allow24.in/mdev/* ; scp -r dist/* new-development:/var/www/allow24.in/mdev",
    "deploy:prod": "ssh bookpro9.com -a rm -rf /var/www/bookpro9.com/mobile/* ; scp -r dist/* bookpro9.com:/var/www/bookpro9.com/mobile",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "dev:ssr": "ng run mobile-view-user:serve-ssr",
    "serve:ssr": "node dist/mobile-view-user/server/main.js",
    "build:ssr": "ng build --configuration production && ng run mobile-view-user:server:production"
  },
  "private": true,
  "dependencies": {
